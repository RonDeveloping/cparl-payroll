// ==========================================
// ===== TENANT SERVICE (Settings)      =====
// ==========================================

model Tenant {
  id                     String   @id @default(cuid())
  contactId              String   @map("contact_id") //soft link only (No @relation)
  primaryContactPersonId String?  @map("primary_contact_person_id") //FK to Contact for the employer's contact person
  nameCached             Json     @map("name_cached")
  slug                   String   @unique
  businessBn9            String?  @map("business_bn9") @db.Char(9)
  businessProgramId      String?  @map("business_program_id") @db.Char(2)
  programRefNum          String?  @map("program_ref_num") @db.Char(4)
  isActive               Boolean  @default(true) @map("is_active")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  members         TenantUser[]
  settings        TenantSettings?
  paySchedules    PaySchedule[]
  payrollUnits    PayrollUnit[]
  departments     Department[]
  subscriptions   TenantSubscription[]
  overtimeConfigs OvertimeConfig[]
  holidayPolicies HolidayPolicy[]

  @@index([businessBn9, businessProgramId, programRefNum])
  @@map("tenant")
}

//TODO: use a middleware or a library (like Prisma's $extends) to automatically inject where: { tenantId: activeTenantId } into every query. This ensures you never forget to filter by the tenant.

model TenantUser {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  role      UserRole @default(EMPLOYEE) @map("role")
  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant @relation(fields: [tenantId], references: [id])
  tenantId String @map("tenant_id")

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_user")
}

model TenantSettings {
  id                String             @id @default(cuid())
  tenantId          String             @unique @map("tenant_id")
  timezone          String             @default("America/Toronto")
  billingEmail      String?            @map("billing_email")
  paymentMethodType PaymentMethodType? @map("payment_method_type")
  paymentSrcId      String?            @map("payment_src_id")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("tenant_settings")
}

model TenantSubscription {
  id                     String             @id @default(cuid())
  tenantId               String             @map("tenant_id")
  planId                 String             @map("plan_id") // soft reference to ServicePlan.id (no hard FK)
  planDisplayName        String             @map("plan_display_name") // cached display name snapshot
  status                 SubscriptionStatus @default(TRIALING)
  billingInterval        BillingInterval    @map("billing_interval")
  currentPeriodStart     DateTime           @map("current_period_start")
  currentPeriodEnd       DateTime           @map("current_period_end")
  cancelAtPeriodEnd      Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt             DateTime?          @map("canceled_at")
  endedAt                DateTime?          @map("ended_at")
  externalSubscriptionId String?            @map("external_subscription_id") // Stripe / Paddle ID if used
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  // Add in migration SQL to enforce one active subscription per tenant:
  // CREATE UNIQUE INDEX one_active_sub_per_tenant
  // ON "tenant_subscription" ("tenant_id")
  // WHERE status IN ('trialing','active','past_due');

  @@index([tenantId, status])
  @@index([planId])
  @@map("tenant_subscription")
}

model Department {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  name     String
  code     String?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@map("department")
}

model PaySchedule {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  payrollUnitId String @map("payroll_unit_id")
  code     String
  name     String
  isActive Boolean @default(true) @map("is_active")

  frequency PayFrequency @map("frequency")

  timingDays         Int      @default(2) @map("timing_days")

  // Period 1 (all frequencies; for SEMIMONTHLY this covers the first half of the month)
  payday        Int?     @map("pay_day")
  payWeekday    Weekday? @map("pay_weekday")
  boundaryShift Int      @map("boundary_shift")
  periodEndDay  Int      @map("period_end_day")
  periodEndWeekday      Weekday? @map("period_end_weekday")

  // Period 2 — populated only when frequency = SEMIMONTHLY (second half of the month)
  payday2        Int?     @map("payday2")
  periodEndDay2  Int?     @map("period_end_day2")
  boundaryShift2 Int?     @map("boundary_shift2")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  payrollUnit PayrollUnit @relation(fields: [payrollUnitId], references: [id])

  @@unique([tenantId, code])
  @@index([payrollUnitId])
  @@index([tenantId, isActive])
  @@map("pay_schedule")
}

model PayrollUnit {
  id       String  @id @default(cuid())
  tenantId String  @map("tenant_id")
  code     String
  name     String
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant              Tenant                @relation(fields: [tenantId], references: [id])
  paySchedules        PaySchedule[]
  employeeAssignments PayrollUnitEmployee[]
  payrollRuns         PayrollRun[]
  glMatrix            PayrollGLMatrix[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("payroll_unit")
}

model PayrollUnitEmployee {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  payrollUnitId String    @map("payroll_unit_id")
  employeeId    String    @map("employee_id")
  startDate     DateTime  @map("start_date")
  endDate       DateTime? @map("end_date")
  isPrimary     Boolean   @default(true) @map("is_primary")
  createdAt     DateTime  @default(now()) @map("created_at")

  payrollUnit PayrollUnit @relation(fields: [payrollUnitId], references: [id])
  employee    Employee    @relation(fields: [employeeId], references: [id])

  @@index([tenantId, employeeId, startDate])
  @@index([payrollUnitId, startDate])
  @@map("payroll_unit_employee")
}

model ChartOfAccount {
  id        String          @id @default(cuid())
  tenantId  String          @map("tenant_id")
  code      String //acct#
  name      String
  type      AccountType
  category  AccountCategory
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  glMappings GLMapping[] // Mapping logic: Which payroll items point here?

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("chart_of_account")
}

model GLMapping {
  id               String         @id @default(cuid())
  tenantId         String         @map("tenant_id")
  chartOfAccountId String         @map("chart_of_account_id")
  mappingType      MappingType    @map("mapping_type")
  earningType      EarningType?   @map("earning_type")
  deductionType    DeductionType? @map("deduction_type")
  departmentId     String?        @map("department_id")

  chartOfAccount ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])

  @@index([tenantId, mappingType])
  @@map("gl_mapping")
}

model PayrollGLMatrix {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  itemClass      ItemClass @map("item_class")
  glAccountId    String    @map("gl_account_id")
  glAccoountName String    @map("gl_account_name")
  isDebit        Boolean   @default(true) @map("is_debit")
  payrollUnitId  String    @map("payroll_unit_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  payrollUnit PayrollUnit @relation(fields: [payrollUnitId], references: [id])

  @@index([tenantId, payrollUnitId])
  @@map("payroll_gl_matrix")
}

enum ItemClass {
  GROSS_PAY
  TAXABLE_ALLOWANCES
  KIND_BENEFITS
  TAXES_PAYABLE
  EMPLOYER_CPP
  EMPLOYER_EI
  CPP_PAYABLE
  EI_PAYABLE
  BENEFITS_PAYABLE
  REASONABLE_ALLOWANCES
  PAYROLL_CLEARING
}

/**
 * KIND_BENEFITS = taxable benefits (e.g., company car, health insurance premiums paid by employer, etc.) can be contra-expense account to vehicle expense or life insurance one.
 * GROSS_REMUNERATION = GROSS_PAY + TAXABLE_ALLOWANCES + KIND_BENEFITS
 * GROSS_PAID = GROSS_PAY + TAXABLE_ALLOWANCES + REASONABLE_ALLOWANCES
 * PAYROLL_CLEARING = GROSS_PAID - (TAXES_PAYABLE + CPP_PAYABLE - EMPLOYER_CPP + EI_PAYABLE - EMPLOYER_EI)
 */
/**
 * mapping flow
 * 1	Line Level	Look at earningType (e.g., "Regular") or deductionType (e.g., "Tax").
 * 2	Employee Level	Look at the departmentId and costCenterId associated with that specific JobAssignment.
 * 3	Mapping Level	Find the GLMapping that matches both the type and the department.
 * 4	Journal Level	Add the amount to the running total for that specific GL Account.
 * journalEntries look like:
 * 5100 - Wages (Eng)	DEBIT	$6,000	Total Regular Pay - Engineering
 * 5100 - Wages (Sales)	DEBIT	$4,000	Total Regular Pay - Sales
 * 2100 - Tax Payable	CREDIT	$2,500	Total Income Tax Withheld
 * 2150 - CPP Payable	CREDIT	$1,000	Total CPP (Employee + Employer)
 * 1010 - Bank Clearing	CREDIT	$6,500	Total Net Pay to be disbursed
 * Granularity: Analyzes every PayrollLine/Deduction, but exports a Summarized Total per GL Account.
 */

// ==========================================
// ===== PAYROLL SERVICE (Logic)        =====
// ==========================================
//the tenantId acts as a Partition Key and provide row level multi-tenancy isolation by veryfying tenantId in all queries
model Employee {
  id             String         @id @default(cuid())
  tenantId       String         @map("tenant_id")
  contactId      String         @map("contact_id")
  employeeNumber String?        @map("employee_number")
  taxIdEncrypted Bytes          @map("tax_id_encrypted")
  taxIdLast4     String         @map("tax_id_last_4") ////last 4 digits for display/search purposes
  dateOfBirth    DateTime       @map("date_of_birth")
  hireDate       DateTime       @map("hire_date")
  status         EmployeeStatus @default(ACTIVE) @map("status")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  // Cached contact info (latest from Contact)
  addressCached  Json           @map("address_cached")
  emailCached    String?        @map("email_cached")
  phoneCached    Json?          @map("phone_cached")
  //array of ojbect e.g. [{ "number": "+1-613-410-8880", "type": "MOBILE", "isPrimary": true }, {"number": "+1-613-555-1234", "type": "WORK", "isPrimary": false }]
  nameCached     Json           @map("name_cached")

  employments            Employment[]
  payrollUnitAssignments PayrollUnitEmployee[]
  payrollRuns            PayrollRunEmployee[]
  bankAccounts           BankAccount[]
  vacationPolicies       VacPolicy[]
  vacationLedgerEntries  VacLedger[]
  holidayLedgerEntries   HolidayLedger[]
  severanceRecords       SeveranceRecord[]

  @@unique([tenantId, contactId]) //for tenant-scoped uniquenessone employee per contact per tenant
  @@unique([tenantId, employeeNumber]) //PostgreSQL allows multiple NULLs, even with a unique constraint, so multiple employees per tenant can have employeeNumber = null
  //@unique,@@unique can only be applied to scalar fields (not relations) and full-table level.
  @@map("employee")
}

/**
 * ALTER TABLE "Employee"
 * ADD CONSTRAINT termination_consistency
 * CHECK ( (terminationDate IS NULL AND terminationReason IS NULL)
 * OR
 * (terminationDate IS NOT NULL AND terminationReason IS NOT NULL)
 * );
 * or/and
 * such both or nothing rules can be enforced in app logic: terminationReason != null ⇒ terminationDate != null; Rehire ⇒ clear both
 */

//TODO: will enforce this in service logic: assert(employment.tenantId === employee.tenantId);Ensure service layer validates that employee.tenantId === employment.tenantId.
model Employment {
  id                String             @id @default(cuid())
  tenantId          String             @map("tenant_id")
  employeeId        String             @map("employee_id")
  title             String?
  department        String?
  startDate         DateTime           @map("start_date")
  endDate           DateTime?          @map("end_date")
  terminationReason TerminationReason? @map("termination_reason")
  countryCode       String             @default("CA") @map("country_code")
  provinceCode      String             @map("province_code")
  createdAt         DateTime           @default(now()) @map("created_at")

  employee       Employee        @relation(fields: [employeeId], references: [id])
  jobAssignments JobAssignment[] ////e.g. casher $18/hr, stocker $20/hr (Most payroll systems — ADP, Ceridian, Workday payroll mode) — support multiple concurrent job assignments per employment record.

  @@index([tenantId, employeeId, startDate]) //tenant-scoped reporting; historical queries and ROE generation
  @@index([employeeId, startDate]) //to speed up querying employment history per employee, ordered by startDate; we can't add an index on WHERE endDate IS NULL to speed up querying current employment record per employee via prisma so far
  @@map("employment")
}

/**
 * TODO: some rule must live at the database level, not the primsa schema level, to enforce data integrity. For example, to ensure that only one active employment record (where endDate IS NULL) exists per employee, we need to create a partial unique index in PostgreSQL by running the following commands in terminal:
 * npx prisma migrate dev --name add-one-active-employment
 * Then in the generated migration.sql file, add:
 * CREATE UNIQUE INDEX "OneActiveEmploymentPerEmployee" ON "Employment" ("employeeId") WHERE "endDate" IS NULL;
 * This ensures that only one active employment record (where endDate IS NULL) exists per employee When violated, Prisma will throw: PrismaClientKnownRequestError#P2002
 * This one active employment rule is for CPP/EI/tax aggregation purposes and for ROE continuity as well as benefit eligibility.
 */

//assume always accessed via Employment, so no tenantId here
//TODO: JobAssignment.startDate >= Employment.startDate; //JobAssignment.endDate <= Employment.endDate (if not null) Note enforcable in Prisma must live in service logic or DB constraints/triggers
model JobAssignment {
  id           String    @id @default(cuid())
  employmentId String    @map("employment_id")
  earningCodeId String   @map("earning_code_id")
  startDate    DateTime  @map("start_date")
  endDate      DateTime? @map("end_date")
  hoursPerWeek Decimal?  @map("hours_per_week") @db.Decimal(6, 2)
  payRate      Decimal   @map("pay_rate") @db.Decimal(10, 2)

  employment   Employment    @relation(fields: [employmentId], references: [id])
  earningCode  EarningCode   @relation(fields: [earningCodeId], references: [id])
  timeEntries  TimeEntry[]
  payrollLines PayrollLine[]

  @@index([employmentId, startDate])
  @@index([earningCodeId])
  @@map("job_assignment")
}

//assume always accessed via jobAssignment, so no tenantId here
model TimeEntry {
  id              String   @id @default(cuid())
  jobAssignmentId String   @map("job_assignment_id")
  workDate        DateTime @map("work_date")
  hours           Decimal  @db.Decimal(6, 2)

  jobAssignment JobAssignment @relation(fields: [jobAssignmentId], references: [id])

  @@index([jobAssignmentId, workDate])
  @@map("time_entry")
}

model PayrollRun {
  id            String           @id @default(cuid())
  tenantId      String           @map("tenant_id") //Add only where filtering / reporting / safety benefits outweigh joins otherwise use of FK chain to validate tenant
  payrollUnitId String?          @map("payroll_unit_id")
  periodStart   DateTime         @map("period_start")
  periodEnd     DateTime         @map("period_end")
  runDate       DateTime         @map("run_date")
  status        PayrollRunStatus @default(DRAFT) @map("status")
  createdAt     DateTime         @default(now()) @map("created_at")

  payrollUnit           PayrollUnit?         @relation(fields: [payrollUnitId], references: [id])
  payrollRunEmployees   PayrollRunEmployee[]
  vacationLedgerEntries VacLedger[]
  holidayLedgerEntries  HolidayLedger[]
  severanceRecords      SeveranceRecord[]

  @@unique([tenantId, payrollUnitId, periodStart, periodEnd]) //prevent duplicate payroll runs for same unit period per tenant
  @@map("payroll_run")
}

/**
 * SUM(hours × payRate) GROUP BY: - employeeId (taxes) - jobAssignmentId (costing)
 * Taxes, CPP, EI → Employee level
 * Earnings → JobAssignment level
 */
model PayrollRunEmployee {
  id              String   @id @default(cuid())
  payrollRunId    String   @map("payroll_run_id")
  employeeId      String   @map("employee_id")
  nameSnapshot    String   @map("name_snapshot") // Immutable snapshot fields copied from Employee
  addressSnapshot String   @map("address_snapshot")
  grossPay        Decimal  @map("gross_pay") @db.Decimal(10, 2)
  deductions      Decimal  @db.Decimal(10, 2)
  netPay          Decimal  @map("net_pay") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")

  payrollRun     PayrollRun            @relation(fields: [payrollRunId], references: [id])
  employee       Employee              @relation(fields: [employeeId], references: [id])
  payrollLines   PayrollLine[]
  deductionsList Deduction[]
  disbursements  PayrollDisbursement[]

  @@unique([payrollRunId, employeeId]) //one record per employee per payroll run
  @@map("payroll_run_employee")
}

//Tenant guaranteed by PayrollRun + Employee; One earning type, for one employee, in one payroll run, attributable to one costing source.
model PayrollLine {
  id                          String           @id @default(cuid())
  payrollRunEmployeeId        String           @map("payroll_run_employee_id")
  jobAssignmentId             String?          @map("job_assignment_id")
  rate                        Decimal          @db.Decimal(10, 2) //payRate from JobAssignment at time of payroll run creation
  units                       Decimal          @db.Decimal(6, 2) //hours from TimeEntry for a payroll period; salary 1 
  amount                      Decimal          @db.Decimal(10, 2)
  earningType                 EarningType      @map("earning_type")
  countsTowardHolidayPay      Boolean          @default(true) @map("counts_toward_holiday_pay")
  countsTowardVacationAccrual Boolean          @default(true) @map("counts_toward_vacation_accrual")
  overtimeDetails             OvertimeDetails?

  payrollRunEmployee PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id])
  jobAssignment      JobAssignment?     @relation(fields: [jobAssignmentId], references: [id])

  @@map("payroll_line")
}

/**
 * Only overtime requires a completely separate child/extension model because of its volatile, event-driven math and compliance requirements.
 */
model OvertimeDetails {
  id            String             @id @default(cuid())
  payrollLineId String             @unique @map("payroll_line_id")
  overtimeRate  Decimal            @db.Decimal(10, 2)
  configId      String             @map("config_id")
  periodType    OvertimePeriodType @default(WEEKLY) @map("period_type")
  workDate      DateTime?          @map("work_date")
  payrollLine   PayrollLine        @relation(fields: [payrollLineId], references: [id], onDelete: Cascade)
  config        OvertimeConfig     @relation(fields: [configId], references: [id])
  regularRate   Decimal            @db.Decimal(10, 2)
  overtimeHours Decimal            @db.Decimal(6, 2)
  totalAmount   Decimal            @db.Decimal(10, 2)
}

model OvertimeConfig {
  id               String        @id @default(cuid())
  tenantId         String        @map("tenant_id")
  provinceCode     ProvinceCode? @map("province_code")
  description      String //e.g., "1.5x after 8 hrs"
  overtimeType     OvertimeType  @map("overtime_type")
  customMultiplier Decimal?      @map("custom_multiplier") @db.Decimal(4, 2) //nullable for standard overtime types
  thresholdHours   Decimal       @db.Decimal(6, 2)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  overtimeDetails OvertimeDetails[]

  @@index([tenantId])
  @@index([tenantId, provinceCode])
  @@map("overtime_config")
}

model Deduction {
  id                   String        @id @default(cuid())
  payrollRunEmployeeId String        @map("payroll_run_employee_id")
  type                 DeductionType @map("type")
  amount               Decimal       @db.Decimal(10, 2)
  createdAt            DateTime      @default(now()) @map("created_at")

  payrollRunEmployee PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id])

  @@unique([payrollRunEmployeeId, type]) //reinforce: one deduction type per payroll run employee
  @@map("deduction")
}

model BankAccount {
  id                String  @id @default(cuid()) @map("id")
  institutionNumber Int     @map("institution_number")
  branchNumber      Int     @map("branch_number")
  accountNumber     String  @map("account_number") // keep as string to preserve leading zeros
  currency          String  @default("CAD") @map("currency")
  isPrimary         Boolean @default(false) @map("is_primary")

  // Distribution Logic
  label    String?          @map("label") // "Main", "Alimony", "Savings"
  type     DistributionType @default(REMAINDER) @map("type")
  value    Decimal?         @map("value") @db.Decimal(10, 2) // The $ or % amount
  priority Int              @default(1) @map("priority") // Process Fixed/Percentage before Remainder
  isActive Boolean          @default(true) @map("is_active")

  // Micro-deposit verification
  verificationStatus BankAccountVerificationStatus @default(UNVERIFIED) @map("verification_status")

  employee   Employee @relation(fields: [employeeId], references: [id])
  // Prisma uses the @relation line to understand how to perform JOINs
  employeeId String   @map("employee_id")

  @@index([employeeId])
  @@map("bank_accounts")
}

model PayrollDisbursement {
  id                   String @id @default(cuid()) @map("id")
  payrollRunEmployeeId String @map("payroll_run_employee_id")

  // Snapshot of bank details at time of payment
  institutionNumber Int     @map("institution_number")
  branchNumber      Int     @map("branch_number")
  accountNumber     String  @map("account_number") // Masked or encrypted in production
  bankLabel         String? @map("bank_label") // e.g., "Personal Savings" or "Alimony"

  amount Decimal            @map("amount") @db.Decimal(10, 2)
  status DisbursementStatus @default(PENDING) @map("status")

  // Tracking for bank file (ACH/EFT) generation
  referenceNumber String?   @map("reference_number") // Trace ID from the bank
  processedAt     DateTime? @map("processed_at")

  payrollRunEmployee PayrollRunEmployee @relation(fields: [payrollRunEmployeeId], references: [id])

  @@index([payrollRunEmployeeId])
  @@map("payroll_disbursements")
}

model PayrollJournal {
  id           String @id @default(cuid()) @map("id")
  payrollRunId String @unique @map("payroll_run_id")
  tenantId     String @map("tenant_id")

  status   JournalStatus @default(PENDING) @map("status")
  postedAt DateTime?     @map("posted_at")

  // Total checks for the entire journal
  totalDebit  Decimal @map("total_debit") @db.Decimal(12, 2)
  totalCredit Decimal @map("total_credit") @db.Decimal(12, 2)

  entries JournalEntry[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@map("payroll_journals")
}

model JournalEntry {
  id               String @id @default(cuid()) @map("id")
  payrollJournalId String @map("payroll_journal_id")

  // Accounting Keys
  glAccountNumber String? @map("gl_account_number") // e.g., "5100" or "2100" for mapping to Chart of Accounts by computer
  glAccountName   String  @map("gl_account_name") // For human readability in exports

  type   EntryType @map("type") // DEBIT or CREDIT
  amount Decimal   @map("amount") @db.Decimal(12, 2)

  description String? @map("description") // e.g., "Gross Wages - Engineering - Period End 2023-10-01"

  journal PayrollJournal @relation(fields: [payrollJournalId], references: [id])

  @@map("journal_entries")
}

model PaySlip {
  id        String   @id @default(uuid()) @map("id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Storage Metadata
  s3Key      String @map("s3_key") // Path: "tenant_id/year/month/file.pdf"
  fileName   String @map("file_name") // e.g., "PaySlip_Jan_2025.pdf"
  fileSize   Int    @map("file_size")
  employeeId String @map("employee_id")
  tenantId   String @map("tenant_id")

  @@index([employeeId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([employeeId, createdAt])
  @@map("pay_slips")
}

model Remittance {
  id       String @id @default(cuid()) @map("id")
  tenantId String @map("tenant_id")

  // The reporting period
  periodYear  Int @map("period_year") // e.g., 2025
  periodMonth Int @map("period_month") // e.g., 12

  // Totals for the filing
  totalGrossPayroll Decimal @map("total_gross_payroll") @db.Decimal(12, 2)
  totalEmployees    Int     @map("total_employees")
  totalDue          Decimal @map("total_due") @db.Decimal(12, 2)

  status           RemittanceStatus @default(PENDING) @map("status")
  paymentReference String?          @map("payment_reference") // Confirmation number from CRA My Business Account
  filedAt          DateTime?        @map("filed_at")

  // Links back to the source data
  payrollRuns RemittanceToPayrollRun[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([tenantId, periodYear, periodMonth])
  @@index([tenantId, status])
  @@map("remittances")
}

model RemittanceToPayrollRun {
  remittanceId String @map("remittance_id")
  payrollRunId String @map("payroll_run_id")

  remittance Remittance @relation(fields: [remittanceId], references: [id])

  @@id([remittanceId, payrollRunId])
  @@map("remittance_to_payroll_runs")
}

model cppEIRates {
  id              String   @id @default(cuid())
  taxYear         Int      @map("tax_year")
  provinceCode    String   @map("province_code") @db.Char(2)
  cppBaseRate     Decimal  @map("cpp_base_rate") @db.Decimal(5, 4) //e.g. 4.95% for 2026
  cppEnhancedRate Decimal  @map("cpp_enhanced_rate") @db.Decimal(5, 4) //e.g. 1%
  cppExemption    Decimal  @map("cpp_exemption") @db.Decimal(5, 4) //e.g. 3.5k  
  cppYMPE         Decimal  @map("cpp_ympe") @db.Decimal(10, 2) //e.g. $74.6K Tier 1 CAP
  cpp2Rate        Decimal  @map("cpp2_rate") @db.Decimal(5, 4) //4%
  cpp2YMPE        Decimal  @map("cpp2_ympe") @db.Decimal(10, 2) //e.g. $85K Tier 2 CAP
  eiRate          Decimal  @map("ei_rate") @db.Decimal(5, 4) //e.g. 1.63% for 2026
  eiMaxEarnings   Decimal  @map("ei_max_earnings") @db.Decimal(10, 2) //e.g. $68.9K
  eiMultiplier    Decimal  @map("ei_multiplier") @db.Decimal(5, 4) //e.g. 1.4
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([taxYear, provinceCode], name: "unique_cpp_ei_rates")
  @@map("cpp_ei_rates")
}

model TaxRate {
  id           String   @id @default(cuid())
  taxYear      Int      @map("tax_year")
  provinceCode String   @map("province_code") @db.Char(2)
  marginalRate Decimal  @map("federal_rate") @db.Decimal(5, 4) //e.g. 15%
  lowerBound   Decimal  @map("lower_bound") @db.Decimal(10, 2) //e.g. $53,359
  upperBound   Decimal? @map("upper_bound") @db.Decimal(10, 2) //e.g. $106,717
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([taxYear, provinceCode], name: "unique_tax_rates")
  @@index([taxYear, provinceCode])
  @@map("tax_rates")
}

model EarningCode {
  id             String      @id @default(cuid())
  tenantId       String      @map("tenant_id")
  code           String      @map("code") //
  description    String      @map("description")
  overrideReason String?     @map("override_reason")
  earningType    EarningType @map("earning_type")
  isHourly       Boolean     @default(true) @map("is_hourly")
  isTaxable      Boolean     @default(true) @map("is_taxable")
  isSubjectToCPP Boolean     @default(true) @map("is_subject_to_cpp")
  isSubjectToEI  Boolean     @default(true) @map("is_subject_to_ei")
  t4BoxNumber    Int?        @map("t4_box_number") //e.g. 14 for regular pay, 71 for taxable benefits, etc.
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  jobAssignments JobAssignment[]

  @@unique([code, tenantId], name: "unique_earning_codes_per_tenant")
  @@map("earning_codes")
}
//suggest codes OVT(overtime), DBL(double), BON, VAC, SCK, BER(bereavement), JRY(jury), PFL(parental leave), CMN(commission), HOL, SEV(severance), RTP(retroactive pay), S10(shift differential), GTL(group term life), AUT(automobile), ALW(allowance), BEN(other benefit), INC(incentive)

model VacPolicy {
  id                       String              @id @default(cuid())
  tenantId                 String              @map("tenant_id")
  employeeId               String              @map("employee_id")
  vacRate                  Decimal             @map("vac_rate") @db.Decimal(5, 4) //e.g. 0.04 for 4%
  isAccrualBased           Boolean             @default(true) @map("is_accrual_based") //true = accrual based, false = lump sum
  vacBalance               Decimal             @map("vac_balance") @db.Decimal(10, 2) //e.g. $1000.00
  balanceUnit              VacationBalanceUnit @default(AMOUNT) @map("balance_unit")
  vacHoursBalance          Decimal?            @map("vac_hours_balance") @db.Decimal(8, 2)
  accrualHoursPerPayPeriod Decimal?            @map("accrual_hours_per_pay_period") @db.Decimal(8, 4)
  accrualStartDate         DateTime?           @map("accrual_start_date")
  payoutOnTermination      Boolean             @default(true) @map("payout_on_termination")
  ledgerEntries            VacLedger[]
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")
  employee                 Employee            @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId], name: "unique_vacation_policy_per_employee")
  @@map("vacation_policy")
}

model VacLedger {
  id            String                  @id @default(cuid())
  tenantId      String                  @map("tenant_id")
  employeeId    String                  @map("employee_id")
  vacPolicyId   String                  @map("vac_policy_id")
  entryType     VacationLedgerEntryType @map("entry_type")
  effectiveDate DateTime                @map("effective_date")
  hours         Decimal?                @db.Decimal(8, 2)
  amount        Decimal                 @map("amount") @db.Decimal(10, 2) //positive = accrual, negative = usage
  payRunId      String?                 @map("payroll_run_id")
  description   String                  @map("description")
  createdAt     DateTime                @default(now()) @map("created_at")
  employee      Employee                @relation(fields: [employeeId], references: [id])
  vacPolicy     VacPolicy               @relation(fields: [vacPolicyId], references: [id])
  payrollRun    PayrollRun?             @relation(fields: [payRunId], references: [id])

  @@index([tenantId, employeeId, effectiveDate])
  @@map("vacation_ledger")
}

model HolidayPolicy {
  id                    String           @id @default(cuid())
  tenantId              String           @map("tenant_id")
  provinceCode          ProvinceCode     @map("province_code")
  method                HolidayPayMethod @map("method")
  averageWindowWeeks    Int?             @default(4) @map("average_window_weeks")
  fixedPercent          Decimal?         @map("fixed_percent") @db.Decimal(5, 4)
  minimumEmploymentDays Int?             @map("minimum_employment_days")
  includeVacationPay    Boolean          @default(false) @map("include_vacation_pay")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  tenant               Tenant          @relation(fields: [tenantId], references: [id])
  holidayLedgerEntries HolidayLedger[]

  @@unique([tenantId, provinceCode], name: "unique_holiday_policy_per_province")
  @@map("holiday_policy")
}

model HolidayLedger {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  employeeId      String   @map("employee_id")
  holidayPolicyId String   @map("holiday_policy_id")
  payrollRunId    String?  @map("payroll_run_id")
  holidayDate     DateTime @map("holiday_date")
  baseEarnings    Decimal  @map("base_earnings") @db.Decimal(10, 2)
  hours           Decimal? @db.Decimal(8, 2)
  amount          Decimal  @db.Decimal(10, 2)
  description     String?  @map("description")
  createdAt       DateTime @default(now()) @map("created_at")

  employee      Employee      @relation(fields: [employeeId], references: [id])
  holidayPolicy HolidayPolicy @relation(fields: [holidayPolicyId], references: [id])
  payrollRun    PayrollRun?   @relation(fields: [payrollRunId], references: [id])

  @@index([tenantId, employeeId, holidayDate])
  @@map("holiday_ledger")
}

model SeveranceRecord {
  id            String     @id @default(cuid())
  payRunId      String     @map("payroll_run_id")
  employeeId    String     @map("employee_id")
  severanceType String     @map("severance_type")
  grossAmount   Decimal    @map("gross_amount") @db.Decimal(10, 2)
  taxWithheld   Decimal    @map("tax_withheld") @db.Decimal(10, 2)
  t4BoxCode     Int        @map("t4_box_code") //e.g. 66 eligible or 67 non-eligible retiring allce.
  createdAt     DateTime   @default(now()) @map("created_at")
  employee      Employee   @relation(fields: [employeeId], references: [id])
  payrollRun    PayrollRun @relation(fields: [payRunId], references: [id])

  @@map("severance_record")
}

// ==========================================
// ===== ENUMS (Lowercase for Postgres) =====
// ==========================================

enum TokenType {
  EMAIL_VERIFICATION @map("email_verification")
  PASSWORD_RESET     @map("password_reset")
  EMAIL_CHANGE       @map("email_change")
  SETUP_PASSWORD     @map("setup_password")

  @@map("token_type")
}

enum UserRole {
  OWNER      @map("owner") // Full access + billing
  ADMIN      @map("admin") // Full payroll access
  MANAGER    @map("manager") // Can view/approve their department only
  ACCOUNTANT @map("accountant") // Read-only access for tax/reports
  EMPLOYEE   @map("employee") // Can only see their own paystubs/profile

  @@map("user_role")
}

//Conflct resolution & precedence USER > SUPPORT > IMPORT > SYSTEM
enum NameSource {
  USER    @map("user")
  SUPPORT @map("support") //e.g. manual change by support agent
  IMPORT  @map("import") //sync from other services than contact management
  SYSTEM  @map("system") //e.g., auto-generated based on rules such as first name variations plus last name etc.

  @@map("conversational_name_source")
}

enum PhoneType {
  MOBILE @map("mobile")
  HOME   @map("home")
  WORK   @map("work")

  @@map("phone_type")
}

enum EmployeeStatus {
  ACTIVE     @map("active")
  TERMINATED @map("terminated")
  INACTIVE   @map("inactive")
}

enum TerminationReason {
  ROE_A_SHORTAGE_OF_WORK                       @map("A") // A - Shortage of work / end of contract or season
  ROE_B_STRIKE_OR_LOCKOUT                      @map("B") // B - Strike or lockout
