// db/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ===== Billing/Subscription service  =====
// ==========================================
model ServicePlan {
  id           String   @id @default(cuid())
  displayName  String   @map("display_name")
  description  String?
  monthlyPrice Decimal  @map("monthly_price") @db.Decimal(10, 2)
  yearlyPrice  Decimal  @map("yearly_price") @db.Decimal(10, 2)
  trialDays    Int      @default(0) @map("trial_days")
  maxEmployees Int?     @map("max_employees") // null = unlimited
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("service_plan")
}

model BillingCustomer {
  id                 String   @id @default(cuid())
  tenantId           String   @unique @map("tenant_id")
  billingEmail       String?  @map("billing_email")
  externalCustomerId String?  @unique @map("external_customer_id")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  invoices            BillingInvoice[]
  paymentTransactions PaymentTransaction[]

  @@index([tenantId])
  @@map("billing_customer")
}

model BillingInvoice {
  id                String          @id @default(cuid())
  billingCustomerId String          @map("billing_customer_id")
  tenantId          String          @map("tenant_id")
  invoiceNumber     String          @unique @map("invoice_number")
  status            InvoiceStatus   @default(DRAFT) @map("status")
  billingInterval   BillingInterval @map("billing_interval")
  periodStart       DateTime        @map("period_start")
  periodEnd         DateTime        @map("period_end")
  currency          String          @default("CAD") @map("currency")
  subtotal          Decimal         @db.Decimal(12, 2)
  taxTotal          Decimal         @map("tax_total") @db.Decimal(12, 2)
  total             Decimal         @db.Decimal(12, 2)
  amountPaid        Decimal         @default(0) @map("amount_paid") @db.Decimal(12, 2)
  dueDate           DateTime?       @map("due_date")
  issuedAt          DateTime?       @map("issued_at")
  paidAt            DateTime?       @map("paid_at")
  voidedAt          DateTime?       @map("voided_at")
  externalInvoiceId String?         @map("external_invoice_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  billingCustomer     BillingCustomer      @relation(fields: [billingCustomerId], references: [id], onDelete: Cascade)
  lineItems           BillingInvoiceLine[]
  paymentTransactions PaymentTransaction[]

  @@index([tenantId, status])
  @@index([billingCustomerId, status])
  @@map("billing_invoice")
}

model BillingInvoiceLine {
  id               String   @id @default(cuid())
  billingInvoiceId String   @map("billing_invoice_id")
  planId           String?  @map("plan_id")
  description      String
  quantity         Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice        Decimal  @map("unit_price") @db.Decimal(12, 2)
  amount           Decimal  @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")

  billingInvoice BillingInvoice @relation(fields: [billingInvoiceId], references: [id], onDelete: Cascade)

  @@index([billingInvoiceId])
  @@index([planId])
  @@map("billing_invoice_line")
}

model PaymentTransaction {
  id                    String            @id @default(cuid())
  billingCustomerId     String            @map("billing_customer_id")
  billingInvoiceId      String?           @map("billing_invoice_id")
  tenantId              String            @map("tenant_id")
  amount                Decimal           @db.Decimal(12, 2)
  currency              String            @default("CAD") @map("currency")
  paymentMethodType     PaymentMethodType @default(CARD) @map("payment_method_type")
  status                PaymentStatus     @default(PENDING) @map("status")
  provider              PaymentProvider   @map("provider")
  cachedPaymentDetails  Json?             @map("payment_method_snapshot") // card example: {"providerPaymentMethodId":"pm_xxx","cardBrand":"visa","cardLast4":"4242"}; PAP example: {"providerPaymentMethodId":"ba_xxx","accountLast4":"6789","institutionNumber":1,"branchNumber":23456}
  providerTransactionId String?           @unique @map("provider_transaction_id")
  failureReason         String?           @map("failure_reason")
  processedAt           DateTime?         @map("processed_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  billingCustomer BillingCustomer @relation(fields: [billingCustomerId], references: [id], onDelete: Cascade)
  billingInvoice  BillingInvoice? @relation(fields: [billingInvoiceId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, paymentMethodType])
  @@index([billingCustomerId, status])
  @@index([billingInvoiceId])
  @@map("payment_transaction")
}

// ==========================================
// ===== USER SERVICE (Authentication)  =====
// ==========================================

model verificationEmailToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([token])
  @@map("verification_email_token")
}

model User {
  id              String    @id @default(cuid()) // Internal, never changes
  slug            String    @unique // Normalized email, all lowercase
  email           String    @unique @map("email") //original format user inputs; case-insensitive in practice.
  emailVerifiedAt DateTime? @map("email_verified_at")
  candidateEmail  String?   @map("candidate_email")

  passwordHash         String?   @map("password_hash")
  termsAcceptedAt      DateTime? @map("terms_accepted_at")
  termsVersionAccepted String?   @map("terms_version_accepted")
  contactId            String    @unique @map("contact_id") // soft link only (No @relation)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  last2FAAt DateTime? @map("last_2fa_at")

  phone           String?   @unique @map("phone")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  pendingPhone    String?   @map("pending_phone")

  twoFactorCode     TwoFactorCode?
  authTokens        AuthToken[]
  phoneVerification PhoneVerification?
  paymentCards      PaymentCard[]
  paymentAccounts   PaymentAccount[]

  @@map("user")
}

model AuthToken {
  id        String    @id @default(cuid())
  token     String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")
  type      TokenType @default(EMAIL_VERIFICATION)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId, type]) // Helps performance when looking up codes for a specific user
  @@map("auth_token")
}

model PhoneVerification {
  id        String   @id @default(cuid())
  code      String // The 6-digit code
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String   @unique @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId]) // Helps performance when looking up codes for a specific user
  @@map("phone_verification")
}

model TwoFactorCode {
  id        String   @id @default(cuid())
  code      String // 6-digit numeric
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId]) // Faster lookup during login
  @@map("two_factor_codes")
}

model PaymentCard {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  brand             String
  last4             String   @map("last4")
  expMonth          Int      @map("exp_month")
  expYear           Int      @map("exp_year")
  cardholderName    String?  @map("cardholder_name")
  billingPostalCode String?  @map("billing_postal_code")
  paymentMethodId   String   @map("payment_method_id")
  isDefault         Boolean  @default(false) @map("is_default")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_card")
}

model PaymentAccount {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  label              String?  @map("label")
  institutionNumber  Int      @map("institution_number")
  branchNumber       Int      @map("branch_number")
  accountNumber      String   @map("account_number") // full account number — encrypt at rest in production
  accountLast4       String   @map("account_last4") // display only
  currency           String   @default("CAD") @map("currency")
  isDefault          Boolean  @default(false) @map("is_default")
  verificationStatus String   @default("unverified") @map("verification_status")
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_accounts")
}

// ==========================================
// ===== CONTACT SERVICE (Identity)     =====
// ==========================================

model Contact {
  id          String      @id @default(cuid())
  coreName    String      @map("core_name") //John/ACE Enterprise
  kindName    String      @map("kind_name") //Doe/Inc.
  middleName  String?     @map("middle_name")
  prefix      String?
  suffix      String?
  aliasName   String?     @map("alias_name") //Johnie a nick name /Starbucks a DBA(doing bz as)
  displayName String?     @map("display_name") //Johnnie Doe
  source      NameSource? @map("source") //USER, SUPPORT, IMPORT, SYSTEM
  subject     Subject

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  legalNameHistory          LegalNameHistory[]
  conversationalNameHistory ConversationalNameHistory[]
  addresses                 Address[]
  emails                    Email[]
  phones                    Phone[]

  @@map("contact")
}

model LegalNameHistory {
  id            String      @id @default(cuid())
  contactId     String      @map("contact_id")
  coreName      String      @map("core_name")
  kindName      String      @map("kind_name")
  middleName    String?     @map("middle_name")
  effectiveFrom DateTime    @map("effective_from")
  effectiveTo   DateTime?   @map("effective_to")
  changedBy     String?     @map("changed_by") //e.g. adminId / system
  reason        String?
  source        NameSource?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade) //so prisma generates the foreign key constraint for us:  ALTER TABLE "LegalNameHistory" ADD CONSTRAINT "LegalNameHistory_contactId_fkey" FOREIGN KEY ("contactId") REFERENCES "Contact"("id") to ensure referential integrity.

  @@index([contactId, effectiveFrom]) //composite index for efficient querying of time in history table
  @@map("legal_name_history")
}

model ConversationalNameHistory {
  id            String      @id @default(cuid())
  contactId     String      @map("contact_id")
  suffix        String?
  prefix        String?
  aliasName     String?     @map("alias_name")
  displayName   String?     @map("display_name")
  source        NameSource?
  effectiveFrom DateTime    @map("effective_from")
  effectiveTo   DateTime?   @map("effective_to")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, effectiveFrom])
  @@map("conversational_name_history")
}

model Address {
  id          String  @id @default(cuid())
  contactId   String  @map("contact_id")
  street      String
  city        String
  province    String
  postalCode  String  @map("postal_code")
  country     String
  addressHash String  @map("address_hash") //sha256(`${street}|${city}|${province}|${postalCode}|${country}`)
  isPrimary   Boolean @default(false) @map("is_primary")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, addressHash]) //composite unique constraint to prevent duplicate addresses for same contact
  @@index([contactId]) //speed up queries per contactID
  @@map("address")
}

model Email {
  id           String   @id @default(cuid())
  contactId    String   @map("contact_id")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  emailAddress String   @map("email_address") //it's case-insensitive in practice, but Prisma does not support unique constraints on case-insensitive yet, so we enforce lowercase in application logic

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, emailAddress])
  @@index([contactId])
  @@map("email")
}

model Phone {
  id        String     @id @default(cuid())
  contactId String     @map("contact_id") //it is explicitly given; direct access to ID w/o fetching the relation; otherwise Prisma will create a hidden field.
  number    String
  type      PhoneType? @default(MOBILE) @map("type")
  isPrimary Boolean    @default(false) @map("is_primary")

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, number])
  @@index([contactId])
  @@map("phone")
}

